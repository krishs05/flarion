# Rust
/target
**/*.rs.bk
# Cargo.lock is committed — Flarion is a binary crate, so pinning transitive
# deps improves reproducibility and makes `cargo audit` results meaningful.

# Model files
*.gguf
*.bin

# Database
*.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env

# Local developer configs (contain host-specific paths)
/my-config.toml

# Local model weights (host-specific, too large to version)
/models/

# Frontend build artifacts
/ui/node_modules
/ui/build
/ui/.svelte-kit
/ui/dist

# Internal planning docs (kept local, not published)
/docs/superpowers/
/.planning/
/.claude/

# Git worktrees (local-only isolated workspaces)
/.worktrees/

# Release artifact staging (populated by build scripts, not source)
/dist/

# Local AI-assistant guidance (kept out of the public repo)
/CLAUDE.md
